# ================================================
# La Campechana - Bot de WhatsApp - Configuración
# ================================================

# --- Meta WhatsApp Business API ---
# Token de acceso permanente (generado en Meta for Developers)
WHATSAPP_TOKEN=your_whatsapp_access_token_here

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Token de verificación del webhook (lo elegís vos, cualquier string seguro)
WEBHOOK_VERIFY_TOKEN=campechana_webhook_secret_2024

# --- Anthropic API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Servidor ---
PORT=3000

# --- Empresa ---
# Datos de contacto para mostrar a los clientes
EMPRESA_DIRECCION=Av. Corrientes 1234, Buenos Aires
EMPRESA_TELEFONO=+54 11 1234-5678
EMPRESA_EMAIL=ventas@lacampechana.com.ar
